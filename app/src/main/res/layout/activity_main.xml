<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/launcherTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launcher_title"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                android:textColor="@color/on_surface" />

            <TextView
                android:id="@+id/launcherActivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="#E6EDF5"
                android:padding="14dp"
                android:text="@string/launcher_live_idle"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="@color/on_surface" />

            <TextView
                android:id="@+id/launcherStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/launcher_status"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="@color/on_surface_variant"
                android:textIsSelectable="true"
                android:typeface="monospace" />

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/kioskAdminButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/kiosk_admin_button_content_description"
        android:padding="4dp"
        android:scaleType="centerInside"
        android:src="@android:drawable/ic_menu_more"
        android:tint="@color/primary"
        android:visibility="visible" />

</FrameLayout>
